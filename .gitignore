# Secrets — never commit
.env
.env.*
credentials.json
token.json
service_account*.json
*_key.json
*_credentials.json
kaggle.json
*.pem
*.key
*.p12

# Temporary processing files — regenerated as needed
.tmp/

# Claude Code — internal agent instructions, not for public repos
CLAUDE.md
.claude/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# OS
.DS_Store
Thumbs.db
.ipynb_checkpoints/

# Power BI Project (PBIP) — machine-specific, not portable source
# localSettings.json holds a DPAPI-encrypted securityBindingsSignature tied
# to the local Windows user account; cache.abf is a disposable local model
# cache. Per Microsoft's own PBIP + git guidance, neither belongs in source
# control — the TMDL/JSON definition files are the actual portable source.
**/.pbi/localSettings.json
**/.pbi/cache.abf
